# Neuron AI - Environment Variables Configuration

# API URL - where the Neuron server is running
# For local development: http://localhost:3000
# For remote server: https://your-server.com:3000
# For ngrok tunnel: https://xxxx-xxxx.ngrok.app
VITE_API_URL=http://localhost:3000

# Optional: App name for UI
VITE_APP_NAME=Neuron Models

# Optional: API timeout in milliseconds
VITE_API_TIMEOUT=10000
