{
  "buildCommand": "npm install --prefix website && npm run build --prefix website",
  "outputDirectory": "website/dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "http://localhost:3000"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:3000/api/:path*"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
