{
  "buildCommand": "cd website && npm install && npm run build",
  "outputDirectory": "website/dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "@VITE_API_URL"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:3000/api/:path*"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
